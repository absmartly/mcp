{
  "name": "@absmartly/mcp",
  "version": "1.0.0",
  "description": "MCP server for ABsmartly — experimentation platform API access for AI assistants",
  "main": "src/index.ts",
  "type": "module",
  "bin": {
    "absmartly-mcp": "./bin/absmartly-mcp.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "public/docs/"
  ],
  "scripts": {
    "prebuild": "node scripts/sync-version.js",
    "build": "tsc",
    "predev": "node scripts/sync-version.js",
    "dev": "wrangler dev",
    "predeploy": "node scripts/sync-version.js",
    "deploy": "npm run test && ./scripts/build-dxt.sh && wrangler deploy",
    "deploy:staging": "npm run test && wrangler deploy --env staging",
    "deploy:production": "npm run test && wrangler deploy --env production",
    "deploy:force": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "start": "wrangler dev",
    "bridge": "node mcp-bridge.js",
    "local-server": "tsx src/local-server.ts",
    "test": "tsx tests/test-runner.js --unit-only",
    "test:unit": "tsx tests/test-runner.js --unit-only",
    "test:integration": "tsx tests/test-runner.js --integration-only",
    "test:all": "tsx tests/test-runner.js",
    "test:resources": "node tests/unit/resources-prompts.test.js",
    "test:legacy": "npm run test:api && npm run test:server && npm run test:bridge",
    "test:server": "node test-server.js",
    "test:bridge": "node test-bridge.js",
    "test:api": "node test-local-api.js",
    "test:claude": "node tests/integration/claude-mcp-tools.test.js",
    "test:dynamic": "node test-dynamic-fields-complete.js",
    "test:dynamic:full": "./run-dynamic-fields-test.sh",
    "precommit": "npm run test",
    "clean-whitespace": "find src -name '*.ts' -exec sed -i '' 's/^[[:space:]]*$//' {} +",
    "build:dxt": "dxt pack",
    "upload:dxt": "./scripts/build-dxt.sh",
    "install:dxt": "npm install -g @anthropic-ai/dxt"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "absmartly",
    "cloudflare-workers",
    "experimentation"
  ],
  "author": "ABsmartly",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.0.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "agents": "^0.0.95",
    "dotenv": "^17.0.0",
    "hono": "^4.8.5",
    "workers-mcp": "^0.0.13",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@absmartly/cli": "^0.1.0",
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/node": "^20.11.0",
    "jsonwebtoken": "^9.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.22.0"
  }
}
