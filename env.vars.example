# OAuth Configuration for Remote MCP Access
# Copy this to .dev.vars for local development

# ABsmartly OAuth Provider (SAML2 → OAuth Bridge)
OAUTH_CLIENT_ID=mcp-absmartly-universal
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
OAUTH_AUTHORIZATION_URL=https://demo-1.absmartly.com/auth/oauth/authorize
OAUTH_TOKEN_URL=https://demo-1.absmartly.com/auth/oauth/token
OAUTH_USERINFO_URL=https://demo-1.absmartly.com/auth/oauth/userinfo

# Legacy Cloudflare Access OAuth Settings (for backwards compatibility)
ACCESS_CLIENT_ID=your_access_client_id_here
ACCESS_CLIENT_SECRET=your_access_client_secret_here
ACCESS_TOKEN_URL=https://your-team.cloudflareaccess.com/oauth/token
ACCESS_AUTHORIZATION_URL=https://your-team.cloudflareaccess.com/oauth/authorize
ACCESS_JWKS_URL=https://your-team.cloudflareaccess.com/cdn-cgi/access/certs

# OAuth Cookie Encryption (generate with: openssl rand -hex 32)
COOKIE_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Allowed email addresses for remote MCP access (comma-separated)
ALLOWED_EMAILS=user1@demo-1.com,user2@demo-1.com

# Default ABsmartly API Configuration (for OAuth users without specific config)
DEFAULT_ABSMARTLY_API_KEY=your_default_api_key_here
DEFAULT_ABSMARTLY_ENDPOINT=https://demo-1.absmartly.com/v1