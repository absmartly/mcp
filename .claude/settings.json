{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run clean-whitespace"
          },
          {
            "type": "command",
            "command": "echo '🚀 Deploying worker after edit...'; npx wrangler deploy --compatibility-date=2025-03-10"
          }
        ]
      }
    ]
  }
}